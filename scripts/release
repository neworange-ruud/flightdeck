#!/usr/bin/env sh
set -eu

if [ -d "${HOME:-}/.cargo/bin" ]; then
  PATH="${HOME}/.cargo/bin:${PATH}"
  export PATH
fi

usage() {
  printf 'Usage: %s <version>\n' "$0" >&2
  printf 'Example: %s 0.2.0\n' "$0" >&2
}

if [ "${1:-}" = "" ]; then
  usage
  exit 2
fi

version="${1#v}"
tag="v${version}"

case "$version" in
  *[!0-9A-Za-z.+-]*|""|*.*.*.*)
    printf 'Invalid SemVer-ish version: %s\n' "$version" >&2
    exit 2
    ;;
  *.*.*) ;;
  *)
    printf 'Version must include major.minor.patch, got: %s\n' "$version" >&2
    exit 2
    ;;
esac

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

require_cmd cargo
require_cmd dist
require_cmd git
require_cmd perl

update_changelog() {
  release_date=$(date +%Y-%m-%d)
  VERSION="$version" RELEASE_DATE="$release_date" perl -0pi -e '
    my $template = <<"EOF";
## [Unreleased]

### New features

- None yet.

### Improvements

- None yet.

### Bug fixes

- None yet.
EOF

    if (/^## \[\Q$ENV{VERSION}\E\] - /m) {
      print STDERR "CHANGELOG.md already has version $ENV{VERSION}; continuing.\n";
      next;
    }

    my ($intro, $tail) = split /^## \[Unreleased\]\n\n/m, $_, 2;
    die "CHANGELOG.md is missing the expected Unreleased section\n" unless defined $tail;

    my ($body, $rest) = $tail =~ /\A(.*?)(?=^## \[|\z)(.*)\z/sm;
    $body =~ s/\A\s+//;
    $body =~ s/\s+\z//;

    my $versioned = "## [$ENV{VERSION}] - $ENV{RELEASE_DATE}\n\n";
    $versioned .= length($body) ? "$body\n\n" : "";

    $_ = $intro . $template . "\n" . $versioned . $rest;
  ' CHANGELOG.md
}

if ! git diff --quiet || ! git diff --cached --quiet; then
  printf 'Working tree must be clean before starting a release.\n' >&2
  exit 1
fi

current_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
if [ "$current_branch" = "" ]; then
  printf 'Release must be run from a local branch, not a detached HEAD.\n' >&2
  exit 1
fi

upstream_ref=$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)
if [ "$upstream_ref" = "" ]; then
  printf 'Current branch has no upstream tracking branch: %s\n' "$current_branch" >&2
  exit 1
fi

upstream_remote=${upstream_ref%%/*}
git fetch "$upstream_remote" --quiet

if ! git merge-base --is-ancestor "$upstream_ref" HEAD; then
  printf 'Local branch is behind %s; update it before cutting a release.\n' "$upstream_ref" >&2
  exit 1
fi

if git rev-parse "$tag" >/dev/null 2>&1; then
  printf 'Tag already exists locally: %s\n' "$tag" >&2
  exit 1
fi

if git ls-remote --exit-code --tags origin "refs/tags/${tag}" >/dev/null 2>&1; then
  printf 'Tag already exists on origin: %s\n' "$tag" >&2
  exit 1
fi

current_version=$(cargo metadata --no-deps --format-version 1 | perl -0ne 'print $1 if /"name":"flightdeck","version":"([^"]+)"/')
if [ "$current_version" = "$version" ]; then
  printf 'Cargo.toml already has version %s; continuing.\n' "$version"
else
  VERSION="$version" perl -0pi -e 's/^version = "[^"]+"/version = "$ENV{VERSION}"/m' Cargo.toml
fi

update_changelog

cargo metadata --format-version 1 >/dev/null

cargo fmt --check
cargo clippy --all-targets --locked -- -D warnings
cargo test --locked
dist generate --check
dist plan --tag "$tag" --allow-dirty

git add Cargo.toml Cargo.lock CHANGELOG.md
if git diff --cached --quiet; then
  printf 'No version-file changes to commit; tagging current HEAD.\n'
else
  git commit -m "Release ${tag}"
fi
git tag -a "$tag" -m "Release ${tag}"
git push origin HEAD
git push origin "$tag"

printf '\nRelease %s pushed. GitHub Actions will build artifacts and publish the GitHub Release.\n' "$tag"
