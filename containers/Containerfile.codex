# FlightDeck base image for the OpenAI Codex CLI agent (SPECS §31).
#
#   podman build -t flightdeck-codex-base:latest -f containers/Containerfile.codex containers
#
# See Containerfile.claude for the base-image contract (Debian-family, non-root
# `agent` user, agent CLI on PATH).
FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git ca-certificates curl ripgrep less zsh \
    && rm -rf /var/lib/apt/lists/*

# Install the Codex CLI.
RUN npm install -g @openai/codex

RUN useradd --create-home --shell /usr/bin/zsh agent
USER agent
WORKDIR /workspace
