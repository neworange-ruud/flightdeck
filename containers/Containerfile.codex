# OPTIONAL reference base image for the OpenAI Codex CLI agent (SPECS §31).
#
# Not needed for the default flow — `flightdeck image build codex` builds a
# self-contained image from docker.io/library/node. Use this only to pre-build a
# base and point `execution.base_image` at it.
#
#   podman build -t flightdeck-codex-base:latest -f containers/Containerfile.codex containers
#
# See Containerfile.claude for the base-image contract.
FROM docker.io/library/node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git ca-certificates curl ripgrep less zsh \
    && rm -rf /var/lib/apt/lists/*

# Install the Codex CLI.
RUN npm install -g @openai/codex

RUN useradd --create-home --shell /usr/bin/zsh agent \
    && mkdir -p /home/agent/.local/state /home/agent/.local/share /home/agent/.config /home/agent/.cache \
    && chmod -R 0777 /home/agent
USER agent
WORKDIR /workspace
