# FlightDeck base image for the opencode (sst) agent (SPECS §31).
#
#   podman build -t flightdeck-opencode-base:latest -f containers/Containerfile.opencode containers
#
# See Containerfile.claude for the base-image contract (Debian-family, non-root
# `agent` user, agent CLI on PATH). Verify the package name for your opencode
# distribution before building.
FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git ca-certificates curl ripgrep less zsh \
    && rm -rf /var/lib/apt/lists/*

# Install the opencode CLI.
RUN npm install -g opencode-ai

RUN useradd --create-home --shell /usr/bin/zsh agent
USER agent
WORKDIR /workspace
